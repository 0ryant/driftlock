{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://driftlock.dev/schemas/0.1.0/mcp-tools.schema.json",
  "title": "Driftlock MCP Tool Manifest",
  "type": "object",
  "required": [
    "tools",
    "resources",
    "prompts"
  ],
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "mutating": {
            "type": "boolean"
          }
        }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "uri",
          "description"
        ],
        "properties": {
          "uri": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
